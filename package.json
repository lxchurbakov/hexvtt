{
    "name": "uberstarter",
    "description": "",
    "version": "1.0.0",
    "scripts": {
        "start": "node -r ts-node/register/transpile-only -r tsconfig-paths/register dist/frm/server.js",
        "dev": "npx run-p server:dev client:dev",
        "build": "NODE_ENV=production npx run-p client:build server:build",
        "server:build": "npx tsc",
        "server:dev": "npx tsx watch -r tsconfig-paths/register frm/server.tsx",
        "client:build": "npx webpack --config frm/webpack.config.ts",
        "client:dev": "npx webpack --watch --config frm/webpack.config.ts"
    },
    "keywords": [
        "react",
        "starter"
    ],
    "author": "lxchurbakov",
    "license": "ISC",
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@types/react-helmet": "^6.1.11",
        "npm-run-all": "^4.1.5",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-helmet": "^6.1.0",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.19.2",
        "typescript": "5.6",
        "webpack": "^5.96.1",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.688.0",
        "dotenv": "^16.4.5",
        "express": "^4.21.1",
        "jsonwebtoken": "^9.0.3",
        "knex": "^3.2.9",
        "nodemailer": "^8.0.4",
        "pg": "^8.13.1",
        "react-router-dom": "^6.28.0",
        "redis": "^4.7.0",
        "styled-components": "^6.1.13",
        "use-between": "^1.3.5",
        "uuid": "^13.0.0"
    }
}
